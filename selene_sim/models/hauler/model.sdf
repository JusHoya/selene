<?xml version="1.0"?>
<sdf version="1.9">
  <model name="hauler">

    <!-- Base chassis -->
    <link name="base_link">
      <pose>0 0 0.14 0 0 0</pose>
      <inertial>
        <mass>83</mass>
        <inertia>
          <ixx>2.76667</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>5.87917</iyy>
          <iyz>0</iyz>
          <izz>8.09250</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.9 0.6 0.2</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.9 0.6 0.2</size>
          </box>
        </geometry>
        <material>
          <ambient>0.4 0.45 0.55 1</ambient>
          <diffuse>0.4 0.45 0.55 1</diffuse>
        </material>
      </visual>

      <!-- IMU sensor -->
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>imu</topic>
      </sensor>

      <!-- Depth camera -->
      <sensor name="depth_camera_sensor" type="depth_camera">
        <pose relative_to="base_link">0.45 0 0.05 0 0 0</pose>
        <update_rate>15</update_rate>
        <topic>depth_camera</topic>
        <camera>
          <horizontal_fov>1.5708</horizontal_fov>
          <image>
            <width>160</width>
            <height>120</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>20.0</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <!-- Front left wheel -->
    <link name="front_left_wheel">
      <pose relative_to="base_link">0.3 0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="front_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Front right wheel -->
    <link name="front_right_wheel">
      <pose relative_to="base_link">0.3 -0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="front_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Mid left wheel -->
    <link name="mid_left_wheel">
      <pose relative_to="base_link">0.0 0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="mid_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="mid_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="mid_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>mid_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Mid right wheel -->
    <link name="mid_right_wheel">
      <pose relative_to="base_link">0.0 -0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="mid_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="mid_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="mid_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>mid_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Rear left wheel -->
    <link name="rear_left_wheel">
      <pose relative_to="base_link">-0.3 0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="rear_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="rear_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Rear right wheel -->
    <link name="rear_right_wheel">
      <pose relative_to="base_link">-0.3 -0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="rear_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="rear_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Transport bin -->
    <link name="transport_bin">
      <pose relative_to="base_link">-0.1 0 0.25 0 0 0</pose>
      <inertial>
        <mass>5</mass>
        <inertia>
          <ixx>0.10417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.14167</iyy>
          <iyz>0</iyz>
          <izz>0.17083</izz>
        </inertia>
      </inertial>
      <collision name="transport_bin_collision">
        <geometry>
          <box>
            <size>0.5 0.4 0.3</size>
          </box>
        </geometry>
      </collision>
      <visual name="transport_bin_visual">
        <geometry>
          <box>
            <size>0.5 0.4 0.3</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.25 0.4 1</ambient>
          <diffuse>0.2 0.25 0.4 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="transport_bin_joint" type="fixed">
      <parent>base_link</parent>
      <child>transport_bin</child>
    </joint>

    <!-- DiffDrive plugin -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>mid_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>mid_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.7</wheel_separation>
      <wheel_radius>0.12</wheel_radius>
      <max_linear_acceleration>0.3</max_linear_acceleration>
      <odom_publish_frequency>20</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- JointStatePublisher plugin -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>

  </model>
</sdf>

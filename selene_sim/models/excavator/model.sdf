<?xml version="1.0"?>
<sdf version="1.9">
  <model name="excavator">

    <!-- Base chassis -->
    <link name="base_link">
      <pose>0 0 0.14 0 0 0</pose>
      <inertial>
        <mass>132</mass>
        <inertia>
          <ixx>4.4</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>7.48</iyy>
          <iyz>0</iyz>
          <izz>11.0</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.8 0.6 0.2</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.8 0.6 0.2</size>
          </box>
        </geometry>
        <material>
          <ambient>0.7 0.4 0.2 1</ambient>
          <diffuse>0.7 0.4 0.2 1</diffuse>
        </material>
      </visual>

      <!-- IMU sensor -->
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>imu</topic>
      </sensor>

      <!-- Depth camera -->
      <sensor name="depth_camera_sensor" type="depth_camera">
        <pose relative_to="base_link">0.4 0 0.05 0 0 0</pose>
        <update_rate>15</update_rate>
        <topic>depth_camera</topic>
        <camera>
          <horizontal_fov>1.5708</horizontal_fov>
          <image>
            <width>160</width>
            <height>120</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>20.0</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <!-- Front left wheel -->
    <link name="front_left_wheel">
      <pose relative_to="base_link">0.3 0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="front_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Front right wheel -->
    <link name="front_right_wheel">
      <pose relative_to="base_link">0.3 -0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="front_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Mid left wheel — passive roller (not driven by DiffDrive plugin).
         Low lateral friction (mu2) so the wheel can slip sideways during
         skid-steer turns instead of dragging the chassis. Without this,
         the 6-wheel layout creates massive scrub and the excavator can
         barely turn. -->
    <link name="mid_left_wheel">
      <pose relative_to="base_link">0.0 0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="mid_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.05</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="mid_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="mid_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>mid_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Mid right wheel — passive roller, see mid_left_wheel comment. -->
    <link name="mid_right_wheel">
      <pose relative_to="base_link">0.0 -0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="mid_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.05</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="mid_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="mid_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>mid_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Rear left wheel -->
    <link name="rear_left_wheel">
      <pose relative_to="base_link">-0.3 0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="rear_left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="rear_left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Rear right wheel -->
    <link name="rear_right_wheel">
      <pose relative_to="base_link">-0.3 -0.35 0 -1.5708 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0078</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0078</iyy>
          <iyz>0</iyz>
          <izz>0.0144</izz>
        </inertia>
      </inertial>
      <collision name="rear_right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="rear_right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.12</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- Drill arm -->
    <link name="drill_arm">
      <pose relative_to="base_link">0.4 0 -0.1 0 0 0</pose>
      <inertial>
        <mass>5</mass>
        <inertia>
          <ixx>0.06933</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.06933</iyy>
          <iyz>0</iyz>
          <izz>0.00533</izz>
        </inertia>
      </inertial>
      <collision name="drill_arm_collision">
        <geometry>
          <box>
            <size>0.08 0.08 0.4</size>
          </box>
        </geometry>
      </collision>
      <visual name="drill_arm_visual">
        <geometry>
          <box>
            <size>0.08 0.08 0.4</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.85 1</ambient>
          <diffuse>0.8 0.8 0.85 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="drill_joint" type="prismatic">
      <parent>base_link</parent>
      <child>drill_arm</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>0</lower>
          <upper>0.3</upper>
        </limit>
      </axis>
    </joint>

    <!-- Hopper -->
    <link name="hopper">
      <pose relative_to="base_link">-0.3 0 0.2 0 0 0</pose>
      <inertial>
        <mass>3</mass>
        <inertia>
          <ixx>0.0325</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0325</iyy>
          <iyz>0</iyz>
          <izz>0.045</izz>
        </inertia>
      </inertial>
      <collision name="hopper_collision">
        <geometry>
          <box>
            <size>0.3 0.3 0.2</size>
          </box>
        </geometry>
      </collision>
      <visual name="hopper_visual">
        <geometry>
          <box>
            <size>0.3 0.3 0.2</size>
          </box>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.2 1</ambient>
          <diffuse>0.6 0.6 0.2 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="hopper_joint" type="fixed">
      <parent>base_link</parent>
      <child>hopper</child>
    </joint>

    <!-- DiffDrive plugin — drives only the front and rear wheels.
         The mid wheels are intentionally NOT listed here so they remain
         passive rollers. A 6-wheel skid-steer with all wheels actively
         driven generates huge scrub at the mid wheels (which sit on the
         turn axis and can't translate sideways), making turns nearly
         impossible. Leaving the mids passive lets them spin freely
         during straight motion and slip during turns. -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.7</wheel_separation>
      <wheel_radius>0.12</wheel_radius>
      <max_linear_acceleration>0.3</max_linear_acceleration>
      <odom_publish_frequency>20</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- JointStatePublisher plugin -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>

  </model>
</sdf>
